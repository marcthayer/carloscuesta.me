section.experience
  .wrap
    h2.section-title Work Experience
    h4.section-subtitle Jobs as a Front End developer.
    .row
    each job in me.workExperience
      article.col-xs-12
        if job.positions.length > 1
          .row
            img.company-logo.lazyload(data-src=job.companyLogo, alt=job.companyName)
            ul.job-positions
              .col-xs-12
                a(href=job.companyWebsite, target="_blank", rel="noopener")
                  h3=job.companyName
                span=job.positions[job.positions.length - 1].dateStart
                span=job.positions[0].dateFinish
                each position in job.positions
                  li
                    div.position-information
                      h4 #{position.title} ·
                      div.position-dates
                        span.position-start=position.dateStart
                        span.position-finish=position.dateFinish
                    p=position.description
        else
          h4=job.positions[0].title
